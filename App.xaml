<Application x:Class="PhoneBook.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PhoneBook.ViewModels"
             xmlns:v="clr-namespace:PhoneBook.Views"
             Startup="Application_Startup">
    <Application.Resources>

        <!--
            DataTemplate связывает тип ViewModel с соответствующим View.
            WPF автоматически выбирает нужный UserControl, когда ContentControl
            получает объект соответствующего типа в качестве Content.
            Явного создания View в коде не требуется — это и есть подход ViewModel-First.
        -->

        <DataTemplate DataType="{x:Type vm:ContactsListViewModel}">
            <v:ContactsListView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ContactEditViewModel}">
            <v:ContactEditView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AboutViewModel}">
            <v:AboutView/>
        </DataTemplate>

    </Application.Resources>
</Application>
